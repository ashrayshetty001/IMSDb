@page "/products/edit"
@attribute [Authorize(Roles = "Administrator")]
@using Microsoft.AspNetCore.Authorization
@using IMSDb.WebApp.Components.Models
@using IMSDb.WebApp.Components.Models.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Data.SqlClient
@using IMSDb.WebApp.Data

@inject DatabaseConnectionManager ConnectionManager
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Edit> Logger

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>
<h2>Product</h2>
<hr />

@if (Product is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Product" OnValidSubmit="UpdateProduct" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />
                <input type="hidden" name="Product.Id" value="@Product.Id" />
                <div class="mb-3">
                    <label for="name" class="form-label">Name:</label>
                    <InputText id="name" @bind-Value="Product.Name" class="form-control" />
                    <ValidationMessage For="() => Product.Name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="quantity" class="form-label">Quantity:</label>
                    <InputNumber id="quantity" @bind-Value="Product.Quantity" class="form-control" />
                    <ValidationMessage For="() => Product.Quantity" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price:</label>
                    <InputNumber id="price" @bind-Value="Product.Price" class="form-control" />
                    <ValidationMessage For="() => Product.Price" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/products" class="btn btn-outline-secondary">Back to List</a>
            </EditForm>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    [SupplyParameterFromForm]
    private Product? Product { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Product == null)
            {
                using var conn = ConnectionManager.GetConnection();
                await conn.OpenAsync();
                var sql = "SELECT Id, Name, Quantity, Price FROM Product WHERE Id = @Id";
                using var cmd = new SqlCommand(sql, conn);
                cmd.Parameters.AddWithValue("@Id", Id);

                using var reader = await cmd.ExecuteReaderAsync();
                if (await reader.ReadAsync())
                {
                    Product = new Product
                    {
                        Id = reader.GetGuid(0),
                        Name = reader.GetString(1),
                        Quantity = reader.GetInt32(2),
                        Price = Convert.ToSingle(reader["Price"])
                    };
                }

                if (Product is null)
                {
                    NavigationManager.NavigateTo("notfound");
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading product for edit.");
        }
    }

    private async Task UpdateProduct()
    {
        bool isSuccess = false;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User.Identity?.Name ?? "Unknown";

            using var conn = ConnectionManager.GetConnection();
            await conn.OpenAsync();
            using var transaction = conn.BeginTransaction();

            try
            {
                var updateSql = "UPDATE Product SET Name = @Name, Quantity = @Quantity, Price = @Price WHERE Id = @Id";
                using (var cmd = new SqlCommand(updateSql, conn, transaction))
                {
                    cmd.Parameters.AddWithValue("@Id", Product!.Id);
                    cmd.Parameters.AddWithValue("@Name", Product.Name);
                    cmd.Parameters.AddWithValue("@Quantity", Product.Quantity);
                    cmd.Parameters.AddWithValue("@Price", Product.Price);
                    await cmd.ExecuteNonQueryAsync();
                }

                var auditSql = @"INSERT INTO product_audits (ProductId, ProductName, Action, ChangedBy, Quantity, Price, ChangedAt) 
                                 VALUES (@ProductId, @ProductName, 'Update', @ChangedBy, @Quantity, @Price, @ChangedAt)";
                using (var auditCmd = new SqlCommand(auditSql, conn, transaction))
                {
                    auditCmd.Parameters.AddWithValue("@ProductId", Product!.Id);
                    auditCmd.Parameters.AddWithValue("@ProductName", Product.Name);
                    auditCmd.Parameters.AddWithValue("@ChangedBy", user);
                    auditCmd.Parameters.AddWithValue("@Quantity", Product.Quantity);
                    auditCmd.Parameters.AddWithValue("@Price", (float)Product.Price);
                    auditCmd.Parameters.AddWithValue("@ChangedAt", DateTime.UtcNow);
                    await auditCmd.ExecuteNonQueryAsync();
                }

                await transaction.CommitAsync();
                Logger.LogInformation("Product updated.");
                isSuccess = true;
            }
            catch (Exception)
            {
                await transaction.RollbackAsync();
                throw;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating product.");
        }

        if (isSuccess) 
        {
            NavigationManager.NavigateTo("/products");
        }
    }
}