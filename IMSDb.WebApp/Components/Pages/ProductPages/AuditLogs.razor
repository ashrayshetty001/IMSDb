@page "/auditlogs"
@using Microsoft.EntityFrameworkCore
@using IMSDb.WebApp.Components.Models.Entities
@inject IDbContextFactory<IMSDb.WebApp.Data.MyAppDbContext> DbFactory

<PageTitle>Product Audit Logs</PageTitle>

<h1>Product Audit Logs</h1>
<p>History of all product modifications.</p>

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Date & Time</th>
            <th>Product Name</th>
            <th>Action</th>
            <th>Changed By</th>
            <th>Logged Qty</th>
            <th>Logged Price</th>
        </tr>
    </thead>
    <tbody>
        @if (audits == null)
        {
            <tr>
                <td colspan="6"><em>Loading...</em></td>
            </tr>
        }
        else if (!audits.Any())
        {
            <tr>
                <td colspan="6">No audits found.</td>
            </tr>
        }
        else
        {
            @foreach (var audit in audits)
            {
                <tr>
                    <td>@audit.ChangedAt.ToLocalTime().ToString("g")</td>
                    <td>@audit.ProductName</td>
                    <td>
                        <span class="badge @GetBadgeClass(audit.Action)">@audit.Action</span>
                    </td>
                    <td>@audit.ChangedBy</td>
                    <td>@audit.Quantity</td>
                    <td>@audit.Price.ToString("C")</td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private List<ProductAudit>? audits;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        // Fetch audits in descending order (newest first)
        audits = await context.ProductAudits
            .OrderByDescending(a => a.ChangedAt)
            .ToListAsync();
    }

    private string GetBadgeClass(string? action)
    {
        return action switch
        {
            "Create" => "bg-success",
            "Update" => "bg-warning text-dark",
            "Delete" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
