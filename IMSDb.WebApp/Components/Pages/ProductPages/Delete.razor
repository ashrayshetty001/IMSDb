@page "/products/delete"
@using IMSDb.WebApp.Components.Models
@using IMSDb.WebApp.Components.Models.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Data.SqlClient
@using IMSDb.WebApp.Data

@inject DatabaseConnectionManager ConnectionManager
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Delete> Logger

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Product</h2>
    <hr />
    @if (product is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@product.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Quantity</dt>
            <dd class="col-sm-10">@product.Quantity</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@product.Price</dd>
        </dl>
        <EditForm method="post" Model="product" OnValidSubmit="DeleteProduct" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(product is null)">Delete</button> |
            <a href="/products" class="btn btn-outline-secondary">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Product? product;

    [SupplyParameterFromQuery]
    private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var conn = ConnectionManager.GetConnection();
            await conn.OpenAsync();
            var sql = "SELECT Id, Name, Quantity, Price FROM Product WHERE Id = @Id";
            using var cmd = new SqlCommand(sql, conn);
            cmd.Parameters.AddWithValue("@Id", Id);

            using var reader = await cmd.ExecuteReaderAsync();
            if (await reader.ReadAsync())
            {
                product = new Product
                {
                    Id = reader.GetGuid(0),
                    Name = reader.GetString(1),
                    Quantity = reader.GetInt32(2),
                    Price = Convert.ToSingle(reader["Price"])
                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing Delete page.");
        }

        if (product is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteProduct()
    {
        bool isSuccess = false;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User.Identity?.Name ?? "Unknown";

            using var conn = ConnectionManager.GetConnection();
            await conn.OpenAsync();
            using var transaction = conn.BeginTransaction();

            try
            {
                var auditSql = @"INSERT INTO product_audits (ProductId, ProductName, Action, ChangedBy, Quantity, Price, ChangedAt) 
                                 VALUES (@ProductId, @ProductName, 'Delete', @ChangedBy, @Quantity, @Price, @ChangedAt)";
                using (var auditCmd = new SqlCommand(auditSql, conn, transaction))
                {
                    auditCmd.Parameters.AddWithValue("@ProductId", product!.Id);
                    auditCmd.Parameters.AddWithValue("@ProductName", product.Name);
                    auditCmd.Parameters.AddWithValue("@ChangedBy", user);
                    auditCmd.Parameters.AddWithValue("@Quantity", product.Quantity);
                    auditCmd.Parameters.AddWithValue("@Price", (float)product.Price);
                    auditCmd.Parameters.AddWithValue("@ChangedAt", DateTime.UtcNow);
                    await auditCmd.ExecuteNonQueryAsync();
                }

                var deleteSql = "DELETE FROM Product WHERE Id = @Id";
                using (var cmd = new SqlCommand(deleteSql, conn, transaction))
                {
                    cmd.Parameters.AddWithValue("@Id", product!.Id);
                    await cmd.ExecuteNonQueryAsync();
                }

                await transaction.CommitAsync();
                Logger.LogInformation("Product deleted.");
                isSuccess = true;
            }
            catch (Exception)
            {
                await transaction.RollbackAsync();
                throw;
            }
            finally
            {
                if (conn != null && conn.State == System.Data.ConnectionState.Open)
                {
                    await conn.CloseAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting product.");
        }

        if (isSuccess)
        {
            NavigationManager.NavigateTo("/products");
        }
    }
}