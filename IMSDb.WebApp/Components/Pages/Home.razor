@page "/"
@page "/dashboard"
@using Microsoft.EntityFrameworkCore
@using IMSDb.WebApp.Components.Models
@using IMSDb.WebApp.Components.Models.Entities
@inject IDbContextFactory<IMSDb.WebApp.Data.MyAppDbContext> DbFactory

<PageTitle>Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h1>Inventory Dashboard</h1>
    <span class="text-muted">Overview of your system</span>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Total Products</h5>
                <h2 class="display-6">@totalProducts</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-danger shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Low Stock Items</h5>
                <h2 class="display-6">@lowStockCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Inventory Value</h5>
                <h2 class="display-6">@inventoryValue.ToString("C")</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-light shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center border border-secondary rounded">
                <a href="/products/create" class="btn btn-outline-primary mb-2">Add New Product</a>
                <a href="/suppliers" class="btn btn-outline-secondary">Manage Suppliers</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Recent Transactions</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Time</th>
                            <th>Action</th>
                            <th>Product</th>
                            <th>User</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (recentAudits == null)
                        {
                            <tr><td colspan="4">Loading...</td></tr>
                        }
                        else if (!recentAudits.Any())
                        {
                            <tr><td colspan="4">No recent activity.</td></tr>
                        }
                        else
                        {
                            @foreach (var audit in recentAudits)
                            {
                                <tr>
                                    <td>@audit.ChangedAt.ToLocalTime().ToString("g")</td>
                                    <td>
                                        @{
                                            var badgeClass = audit.Action == "Create" ? "bg-success" :
                                                             audit.Action == "Update" ? "bg-warning text-dark" : "bg-danger";
                                        }
                                        <span class="badge @badgeClass">@audit.Action</span>
                                    </td>
                                    <td>@audit.ProductName</td>
                                    <td>@audit.ChangedBy</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalProducts = 0;
    private int lowStockCount = 0;
    private double inventoryValue = 0;
    private List<ProductAudit>? recentAudits;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        totalProducts = await context.Product.CountAsync();
        lowStockCount = await context.Product.Where(p => p.Quantity < 10).CountAsync();
        
        var allProducts = await context.Product.ToListAsync();
        inventoryValue = allProducts.Sum(p => p.Price * p.Quantity);

        recentAudits = await context.ProductAudits
            .OrderByDescending(a => a.ChangedAt)
            .Take(5)
            .ToListAsync();
    }
}
